{
  "name": "sf-archguard",
  "version": "0.1.0",
  "description": "ArchUnit-style architecture enforcement for Salesforce SFDX projects",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "sf-archguard": "dist/cli.js"
  },
  "exports": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.config.cjs",
    "lint": "eslint src/**/*.ts"
  },
  "keywords": [
    "salesforce",
    "sfdx",
    "architecture",
    "dependency",
    "enforcement"
  ],
  "license": "MIT",
  "oclif": {
    "commands": "./dist/commands",
    "bin": "sf",
    "topicSeparator": " ",
    "topics": {
      "archguard": {
        "description": "Architecture enforcement commands for Salesforce projects"
      }
    },
    "flexibleTaxonomy": true
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "messages",
    "!dist/**/*.map"
  ],
  "dependencies": {
    "@oclif/core": "^4.9.0",
    "@salesforce/core": "^8.27.0",
    "@salesforce/sf-plugins-core": "^12.2.6",
    "chalk": "^4.1.2",
    "commander": "^12.0.0",
    "fast-xml-parser": "^4.3.0",
    "glob": "^10.3.0",
    "yaml": "^2.4.0"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.4.0"
  }
}

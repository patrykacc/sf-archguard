{
  "name": "sf-archguard",
  "version": "0.2.1",
  "description": "ArchUnit-style architecture enforcement for Salesforce SFDX projects",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "sf-archguard": "dist/cli.js"
  },
  "exports": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.config.cjs",
    "lint": "npm run typecheck",
    "pack:check": "npm pack --dry-run",
    "release:check": "npm run build && npm run lint && npm test && npm run pack:check",
    "prepublishOnly": "npm run release:check"
  },
  "keywords": [
    "salesforce",
    "sfdx",
    "sf-plugin",
    "oclif",
    "architecture",
    "archunit",
    "dependency",
    "enforcement",
    "apex",
    "static-analysis"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "oclif": {
    "commands": "./dist/commands",
    "bin": "sf",
    "topicSeparator": " ",
    "topics": {
      "archguard": {
        "description": "Architecture enforcement commands for Salesforce projects"
      }
    },
    "flexibleTaxonomy": true
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "messages",
    "LICENSE",
    "!dist/**/*.map"
  ],
  "dependencies": {
    "@apexdevtools/apex-parser": "5.0.0-beta.5",
    "@inquirer/prompts": "^8.3.2",
    "@oclif/core": "^4.9.0",
    "@salesforce/core": "^8.27.0",
    "@salesforce/sf-plugins-core": "^12.2.6",
    "chalk": "^4.1.2",
    "commander": "^12.0.0",
    "fast-xml-parser": "^5.5.9",
    "glob": "^10.3.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.4.0"
  }
}
